apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

resources:
  - ../../base

namespace: {{ project_slug }}-dev

patches:
  - patch: |-
      apiVersion: apps/v1
      kind: Deployment
      metadata:
        name: {{ project_slug }}
      spec:
        replicas: 1
        template:
          spec:
            containers:
              - name: {{ project_slug }}
                resources:
                  requests:
                    cpu: 50m
                    memory: 128Mi
                  limits:
                    cpu: 250m
                    memory: 256Mi
                env:
                  - name: LOG_LEVEL
                    value: DEBUG
                  - name: DEBUG
                    value: "true"
