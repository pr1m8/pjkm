import type { NextConfig } from "next";

const nextConfig: NextConfig = {
  // API proxy to Python backend during development
  async rewrites() {
    return [
      {
        source: "/api/:path*",
        destination: `${process.env.API_URL || "http://localhost:8000"}/api/:path*`,
      },
    ];
  },
};

export default nextConfig;
