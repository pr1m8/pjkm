"""Celery application configuration."""

from __future__ import annotations

import os

from celery import Celery

# Broker: Redis by default, override with CELERY_BROKER_URL
broker_url = os.getenv("CELERY_BROKER_URL", "redis://localhost:6379/0")
result_backend = os.getenv("CELERY_RESULT_BACKEND", "redis://localhost:6379/1")

app = Celery(
    "{{ project_slug }}",
    broker=broker_url,
    backend=result_backend,
)

app.conf.update(
    # Serialization
    task_serializer="json",
    accept_content=["json"],
    result_serializer="json",
    # Timezone
    timezone="UTC",
    enable_utc=True,
    # Reliability
    task_acks_late=True,
    worker_prefetch_multiplier=1,
    task_reject_on_worker_lost=True,
    # Results
    result_expires=3600,  # 1 hour
    # Task routing (example)
    task_routes={
        "{{ project_slug }}.workers.tasks.*": {"queue": "default"},
    },
)

# Auto-discover tasks in the workers package
app.autodiscover_tasks(["{{ project_slug }}.workers"])
