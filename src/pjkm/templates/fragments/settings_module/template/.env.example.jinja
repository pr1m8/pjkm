# {{ project_name }} — environment variables
# Copy to .env and fill in values: cp .env.example .env

# App
APP_NAME="{{ project_name }}"
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Server
HOST=0.0.0.0
PORT=8000

# Database (uncomment if using database group)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/{{ project_slug }}

# Redis (uncomment if using redis group)
# REDIS_URL=redis://localhost:6379/0

# Auth (uncomment if using auth group)
# JWT_SECRET_KEY=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_MINUTES=30
