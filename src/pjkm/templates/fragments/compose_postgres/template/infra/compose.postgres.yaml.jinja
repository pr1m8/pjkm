services:
  postgres:
    image: pgvector/pgvector:pg17
    restart: unless-stopped
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    environment:
      POSTGRES_USER: "${POSTGRES_USER:-{{ project_slug }}}"
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD:-{{ project_slug }}}"
      POSTGRES_DB: "${POSTGRES_DB:-{{ project_slug }}}"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-{{ project_slug }}}"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  pgdata:
