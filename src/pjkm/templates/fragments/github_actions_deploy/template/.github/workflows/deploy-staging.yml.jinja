name: Deploy to Staging

on:
  push:
    branches: [main]

permissions:
  contents: read
  deployments: write

concurrency:
  group: staging
  cancel-in-progress: true

jobs:
  deploy:
    runs-on: ubuntu-latest
    environment:
      name: staging
      url: https://staging.{{ project_slug }}.example.com
    steps:
      - uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to registry
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: {% raw %}${{ github.actor }}{% endraw %}
          password: {% raw %}${{ secrets.GITHUB_TOKEN }}{% endraw %}

      - name: Build and push
        uses: docker/build-push-action@v6
        with:
          context: .
          push: true
          tags: ghcr.io/{% raw %}${{ github.repository }}{% endraw %}:staging
          cache-from: type=gha
          cache-to: type=gha,mode=max

      - name: Deploy
        run: |
          echo "Deploy to staging environment"
          echo "Override this step with your deployment command"
          # Examples:
          # kubectl set image deployment/{{ project_slug }} app=ghcr.io/{% raw %}${{ github.repository }}{% endraw %}:staging
          # flyctl deploy --image ghcr.io/{% raw %}${{ github.repository }}{% endraw %}:staging
          # ssh deploy@staging 'docker pull ... && docker compose up -d'
