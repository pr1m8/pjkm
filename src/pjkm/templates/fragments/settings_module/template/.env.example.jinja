# {{ project_name }} — environment variables
# Copy to .env and fill in values: cp .env.example .env

# App
APP_NAME="{{ project_name }}"
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# Server
HOST=0.0.0.0
PORT=8000
{% if "database" in groups %}

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/{{ project_slug }}
{% endif %}
{% if "redis" in groups %}

# Redis
REDIS_URL=redis://localhost:6379/0
{% endif %}
{% if "auth" in groups %}

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
{% endif %}
{% if "s3" in groups or "file_upload" in groups %}

# S3 / Object Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET={{ project_slug }}-uploads
{% endif %}
{% if "celery" in groups %}

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
{% endif %}
{% if "email" in groups %}

# Email
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM={{ project_slug }}@example.com
{% endif %}
{% if "error_tracking" in groups %}

# Error Tracking
SENTRY_DSN=
{% endif %}
