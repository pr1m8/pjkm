"""Application settings loaded from environment variables and .env files."""

from __future__ import annotations

from functools import lru_cache

from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    """Central configuration — reads from .env, env vars, or defaults."""

    model_config = SettingsConfigDict(
        env_file=".env",
        env_file_encoding="utf-8",
        extra="ignore",
    )

    # App
    app_name: str = "{{ project_name }}"
    app_env: str = "development"
    debug: bool = False
    log_level: str = "INFO"
    secret_key: str = "change-me-in-production"

    # Server
    host: str = "0.0.0.0"
    port: int = 8000
{% if "database" in groups %}

    # Database
    database_url: str = "postgresql+asyncpg://postgres:postgres@localhost:5432/{{ project_slug }}"
{% endif %}
{% if "redis" in groups %}

    # Redis
    redis_url: str = "redis://localhost:6379/0"
{% endif %}
{% if "auth" in groups %}

    # Auth
    jwt_secret_key: str = "change-me-in-production"
    jwt_algorithm: str = "HS256"
    jwt_expire_minutes: int = 30
{% endif %}
{% if "s3" in groups or "file_upload" in groups %}

    # S3 / Object Storage
    s3_endpoint_url: str = "http://localhost:9000"
    s3_access_key: str = "minioadmin"
    s3_secret_key: str = "minioadmin"
    s3_bucket: str = "{{ project_slug }}-uploads"
{% endif %}
{% if "email" in groups %}

    # Email
    smtp_host: str = "localhost"
    smtp_port: int = 587
    smtp_user: str = ""
    smtp_password: str = ""
    email_from: str = "{{ project_slug }}@example.com"
{% endif %}

    @property
    def is_production(self) -> bool:
        return self.app_env == "production"

    @property
    def is_development(self) -> bool:
        return self.app_env == "development"


@lru_cache
def get_settings() -> Settings:
    """Cached settings singleton — call this instead of Settings() directly."""
    return Settings()
