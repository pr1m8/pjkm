SHELL := /bin/bash
.DEFAULT_GOAL := help

# ==============================================================================
# {{ project_name }} Makefile (poly-repo)
# ==============================================================================
# Modular sections are in make/*.mk — add/remove includes as needed.

-include make/docker.mk
-include make/python.mk
-include make/db.mk
-include make/redis.mk
-include make/network.mk
-include make/diagnostics.mk
-include make/clean.mk
-include make/help.mk

# ── Packages / Submodules ────────────────────────────

.PHONY: submodules install-packages install-all

submodules: ## Initialize and update git submodules
	git submodule update --init --recursive

install-packages: ## Install all sub-packages in packages/
	@for dir in packages/*/; do \
		if [ -f "$$dir/pyproject.toml" ]; then \
			echo "Installing $$dir..."; \
			(cd "$$dir" && pdm install) || true; \
		fi; \
	done

install-all: install install-packages ## Install root + all sub-packages
