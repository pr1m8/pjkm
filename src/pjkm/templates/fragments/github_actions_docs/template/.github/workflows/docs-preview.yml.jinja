name: Docs Preview

on:
  pull_request:
    paths:
      - "docs/**"
      - "src/**/*.py"
      - "mkdocs.yml"
      - "pyproject.toml"

permissions:
  contents: read
  pull-requests: write

concurrency:
  group: {% raw %}docs-preview-${{ github.ref }}{% endraw %}
  cancel-in-progress: true

jobs:
  preview:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install PDM
        uses: pdm-project/setup-pdm@v4
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies
        run: pdm install -G docs

      - name: Build docs
        run: pdm run sphinx-build -W -b html docs/ docs/_build/html

      - name: Upload artifact
        uses: actions/upload-artifact@v4
        with:
          name: docs-preview
          path: docs/_build/html/
          retention-days: 5

      - name: Comment PR with docs link
        uses: marocchino/sticky-pull-request-comment@v2
        with:
          header: docs-preview
          message: |
            :books: **Docs built successfully.**
            Download the artifact to preview locally.
