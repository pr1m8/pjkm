name: Kubernetes Lint

on:
  push:
    branches: [main]
    paths:
      - "k8s/**"
      - "helm/**"
  pull_request:
    paths:
      - "k8s/**"
      - "helm/**"

permissions:
  contents: read

jobs:
  kube-lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install kubeconform
        run: |
          curl -fsSL https://github.com/yannh/kubeconform/releases/latest/download/kubeconform-linux-amd64.tar.gz | tar xz
          sudo mv kubeconform /usr/local/bin/

      - name: Validate Kubernetes manifests
        run: |
          find k8s/ -name '*.yaml' -o -name '*.yml' | \
            xargs kubeconform -strict -summary -output json

  helm-lint:
    runs-on: ubuntu-latest
    if: hashFiles('helm/') != ''
    steps:
      - uses: actions/checkout@v4

      - name: Set up Helm
        uses: azure/setup-helm@v4

      - name: Lint Helm chart
        run: helm lint helm/

      - name: Template Helm chart
        run: helm template {{ project_slug }} helm/ --debug
