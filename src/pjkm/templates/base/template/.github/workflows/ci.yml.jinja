name: CI

on:
  push:
    branches: [main]
  pull_request:

permissions:
  contents: read

concurrency:
  group: {% raw %}${{ github.workflow }}-${{ github.ref }}{% endraw %}
  cancel-in-progress: true

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install PDM
        uses: pdm-project/setup-pdm@v4
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies
        run: pdm install -G testing -G coverage

      - name: Run tests with coverage
        run: pdm run pytest --cov --cov-report=xml --cov-report=term-missing

      - name: Upload coverage report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: coverage-report
          path: coverage.xml

  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install PDM
        uses: pdm-project/setup-pdm@v4
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies
        run: pdm install -G linting

      - name: Ruff lint
        run: pdm run ruff check . --output-format=github

      - name: Ruff format
        run: pdm run ruff format --check .

  typecheck:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install PDM
        uses: pdm-project/setup-pdm@v4
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies
        run: pdm install -G typecheck

      - name: Pyright
        run: pdm run pyright src/

  docs:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install PDM
        uses: pdm-project/setup-pdm@v4
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies
        run: pdm install -G docs

      - name: Build docs
        run: pdm run sphinx-build -W -b html docs/ docs/_build/html

      - name: Upload docs artifact
        uses: actions/upload-artifact@v4
        with:
          name: docs-html
          path: docs/_build/html/

  security:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install PDM
        uses: pdm-project/setup-pdm@v4
        with:
          python-version: "{{ python_version }}"

      - name: Install dependencies
        run: pdm install -G security

      - name: Bandit security scan
        run: pdm run bandit -r src/ -f json -o bandit-report.json || true

      - name: Upload security report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: security-report
          path: bandit-report.json
