# EditorConfig: https://editorconfig.org
root = true

# ----------------------------------------------------------------------
# Defaults
# ----------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
tab_width = 4

# ----------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------
[*.py]
indent_style = space
indent_size = 4

[*.pyi]
indent_style = space
indent_size = 4

# ----------------------------------------------------------------------
# TOML / PDM
# ----------------------------------------------------------------------
[*.toml]
indent_style = space
indent_size = 2

[pyproject.toml]
indent_style = space
indent_size = 2

[.pdm-python]
indent_style = space
indent_size = 2

# ----------------------------------------------------------------------
# YAML (CI, pre-commit, Trunk, workflows)
# ----------------------------------------------------------------------
[*.{yml,yaml}]
indent_style = space
indent_size = 2

[.pre-commit-config.yaml]
indent_style = space
indent_size = 2

# ----------------------------------------------------------------------
# JSON (incl. Jupyter notebooks)
# ----------------------------------------------------------------------
[*.json]
indent_style = space
indent_size = 2

[*.ipynb]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
insert_final_newline = true

[*.{jsonc,json5}]
indent_style = space
indent_size = 2

# ----------------------------------------------------------------------
# Markdown / docs — keep double-space line breaks
# ----------------------------------------------------------------------
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.rst]
indent_style = space
indent_size = 2

[*.mdx]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Config files
[*.{ini,cfg,conf}]
indent_style = space
indent_size = 2

# ----------------------------------------------------------------------
# Shell / env
# ----------------------------------------------------------------------
[*.{sh,bash}]
indent_style = space
indent_size = 2

[*.env]
indent_style = space
indent_size = 2

# Windows batch files
[*.{bat,cmd}]
indent_style = tab
tab_width = 4
end_of_line = crlf

# ----------------------------------------------------------------------
# Web / Frontend
# ----------------------------------------------------------------------
[*.{html,css,scss,less,js,jsx,ts,tsx,cjs,mjs,vue}]
indent_style = space
indent_size = 2

[*.{xml,svg}]
indent_style = space
indent_size = 2

# Templating
[*.{jinja,jinja2,j2,tmpl,hbs}]
indent_style = space
indent_size = 2

# ----------------------------------------------------------------------
# Data / SQL / Infra
# ----------------------------------------------------------------------
[*.{sql,csv,tsv}]
indent_style = space
indent_size = 2

[*.{tf,tfvars,hcl}]
indent_style = space
indent_size = 2

[Dockerfile]
indent_style = space
indent_size = 2

[Dockerfile.*]
indent_style = space
indent_size = 2

# ----------------------------------------------------------------------
# Makefiles (tabs required)
# ----------------------------------------------------------------------
[Makefile]
indent_style = tab
tab_width = 4

[*.mk]
indent_style = tab
tab_width = 4

# ----------------------------------------------------------------------
# Git metadata
# ----------------------------------------------------------------------
[.gitignore]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[.gitattributes]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[.gitmodules]
indent_style = space
indent_size = 2

# ----------------------------------------------------------------------
# Patches / diffs — preserve whitespace exactly
# ----------------------------------------------------------------------
[*.{patch,diff}]
trim_trailing_whitespace = false
insert_final_newline = false

# ----------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------
[*.{txt,log}]
indent_style = space
indent_size = 2

[.editorconfig]
indent_style = space
indent_size = 2

[.secrets.baseline]
indent_style = space
indent_size = 2
